# ==================================================
# Company Data Enrichment System — Environment Template
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.
# ==================================================

# --------------------------------------------------
# LLM / OpenAI  (REQUIRED for AI enrichment)
# --------------------------------------------------
OPENAI_API_KEY=sk-...your-key-here...
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.0
OPENAI_MAX_TOKENS=1024

# --------------------------------------------------
# File Paths (relative to project root)
# Defaults are fine for most setups — only change
# if you want to override the default locations.
# --------------------------------------------------
# INPUT_DIR=data/input
# OUTPUT_DIR=data/output
# LOG_DIR=logs
# CACHE_DIR=.cache
# PROMPTS_DIR=prompts

# --------------------------------------------------
# HTTP / Scraping
# --------------------------------------------------
REQUEST_TIMEOUT=15
MAX_RETRIES=3
RETRY_BACKOFF_FACTOR=1.5
RESPECT_ROBOTS_TXT=true
# SCRAPER_USER_AGENT=Mozilla/5.0 (compatible; CompanyEnrichmentBot/1.0)

# --------------------------------------------------
# Rate Limiting
# --------------------------------------------------
REQUESTS_PER_SECOND=2.0
LLM_REQUESTS_PER_MINUTE=60

# --------------------------------------------------
# Concurrency
# --------------------------------------------------
MAX_WORKERS=10
BATCH_SIZE=50

# --------------------------------------------------
# Enrichment Behaviour
# --------------------------------------------------
MIN_CONFIDENCE_THRESHOLD=30
SKIP_ALREADY_ENRICHED=true
MAX_TEXT_CHARS_FOR_LLM=8000
FUZZY_NAME_THRESHOLD=90

# --------------------------------------------------
# Optional Third-Party Enrichment APIs
# Leave blank to skip the corresponding source.
# --------------------------------------------------
CLEARBIT_API_KEY=
HUNTER_API_KEY=
SERPAPI_KEY=
